# Copy to `.env` and fill in. `.env` is gitignored and must never be committed.
#
# EXPO_PUBLIC_ variables are inlined into the JavaScript bundle at build time,
# which means they ship inside the APK and are readable by anyone who installs
# it. Only put the publishable (anon) key here — never a `sb_secret_` or
# service_role key. The anon key is safe to expose only because Row Level
# Security grants it nothing by default; see supabase/migrations/0001_schema.sql.

EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<publishable-anon-key>
