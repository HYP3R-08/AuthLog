#ifndef SECRETS_H
#define SECRETS_H

// Copy this file to `secrets.h` and fill in your own values.
// `secrets.h` is listed in .gitignore and must never be committed.

#define WIFI_SSID       "your-network-name"
#define WIFI_PASSWORD   "your-network-password"

// Base URL of the deployed Edge Function, without a trailing slash.
// Example: https://<project-ref>.functions.supabase.co/verify-access
#define VERIFY_ENDPOINT "https://<project-ref>.functions.supabase.co/verify-access"

// Per-device token. This is NOT a Supabase key: it is a random string that the
// Edge Function checks against its own DEVICE_TOKEN secret. Generate one with:
//   openssl rand -hex 32
// If a device is lost, rotate this value and redeploy the function; no Supabase
// credential is ever exposed.
#define DEVICE_TOKEN    "generate-with-openssl-rand-hex-32"

// Root CA that signs the Supabase endpoint certificate, in PEM form.
// Fetch the chain and copy the *root* certificate:
//   openssl s_client -showcerts -connect <project-ref>.functions.supabase.co:443
// Certificates expire: when the endpoint stops validating, refresh this value.
#define SUPABASE_ROOT_CA \
  "-----BEGIN CERTIFICATE-----\n" \
  "...paste the root CA here...\n" \
  "-----END CERTIFICATE-----\n"

#endif  // SECRETS_H
